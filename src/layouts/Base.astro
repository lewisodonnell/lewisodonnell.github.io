---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <script is:inline>
      // Gate for scroll-effect styles: without JS the page renders fully
      // visible, with no hidden reveal states. Also restores an explicit
      // theme choice before first paint so there is no flash.
      document.documentElement.classList.add('js');
      try {
        const theme = localStorage.getItem('theme');
        if (theme === 'dark' || theme === 'light')
          document.documentElement.setAttribute('data-theme', theme);
      } catch {}
    </script>
    <slot name="head" />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <slot />
    <Footer />
    <script is:inline>
      // The site's only JavaScript (small, no dependencies): theme toggle,
      // scroll reveals, self-drawing wave dividers, section-panel entrances,
      // 3D card tilt + spotlight, hero parallax, nav state, and scroll-spy.
      (() => {
        const motionOK = !matchMedia('(prefers-reduced-motion: reduce)')
          .matches;

        // Per-section accent: the section currently in view recolours the
        // whole page (nav, waves, spotlight, link hovers) via --accent.
        let currentSection = null;
        const isDark = () => {
          const root = document.documentElement;
          return (
            root.getAttribute('data-theme') === 'dark' ||
            (!root.getAttribute('data-theme') &&
              matchMedia('(prefers-color-scheme: dark)').matches)
          );
        };
        const applyAccent = () => {
          const root = document.documentElement;
          const colour =
            currentSection &&
            (isDark()
              ? currentSection.dataset.accentDark
              : currentSection.dataset.accent);
          if (colour) root.style.setProperty('--accent', colour);
          else root.style.removeProperty('--accent');
        };
        matchMedia('(prefers-color-scheme: dark)').addEventListener(
          'change',
          applyAccent,
        );

        const toggle = document.querySelector('[data-theme-toggle]');
        if (toggle) {
          toggle.addEventListener('click', () => {
            const next = isDark() ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            try {
              localStorage.setItem('theme', next);
            } catch {}
            applyAccent();
          });
        }

        const nav = document.querySelector('[data-nav]');
        if (nav) {
          const onScroll = () =>
            nav.classList.toggle('scrolled', window.scrollY > 8);
          onScroll();
          addEventListener('scroll', onScroll, { passive: true });
        }

        // Toggled (not one-shot) so the reveals and wave draws replay every
        // time an element scrolls back into view. On exit we record which
        // edge the element left through — it re-enters from that side
        // (data-from drives the direction-aware hidden transforms).
        const reveal = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
              } else {
                entry.target.classList.remove('in-view');
                entry.target.dataset.from =
                  entry.boundingClientRect.top < 0 ? 'above' : 'below';
              }
            }
          },
          { rootMargin: '0px 0px -8% 0px' },
        );
        document
          .querySelectorAll('.reveal, svg.divider, .section')
          .forEach((el) => reveal.observe(el));

        if (motionOK) {
          // 3D tilt toward the cursor + spotlight position.
          document.querySelectorAll('.card').forEach((card) => {
            card.addEventListener('mousemove', (e) => {
              const r = card.getBoundingClientRect();
              const px = (e.clientX - r.left) / r.width;
              const py = (e.clientY - r.top) / r.height;
              card.style.transition =
                'transform 120ms ease, box-shadow 300ms ease, border-color 300ms ease';
              card.style.transform =
                'perspective(700px)' +
                ` rotateX(${((0.5 - py) * 6).toFixed(2)}deg)` +
                ` rotateY(${((px - 0.5) * 8).toFixed(2)}deg)` +
                ' translateY(-4px)';
              card.style.setProperty('--mx', (px * 100).toFixed(1) + '%');
              card.style.setProperty('--my', (py * 100).toFixed(1) + '%');
            });
            card.addEventListener('mouseleave', () => {
              card.style.transform = '';
              card.style.transition = '';
            });
          });

          // The hero recedes and fades as the first panel arrives.
          const hero = document.querySelector('[data-hero]');
          if (hero) {
            addEventListener(
              'scroll',
              () => {
                const y = window.scrollY;
                if (y < window.innerHeight) {
                  hero.style.transform = `translateY(${(y * 0.28).toFixed(1)}px)`;
                  hero.style.opacity = String(
                    Math.max(0, 1 - y / (window.innerHeight * 0.9)),
                  );
                }
              },
              { passive: true },
            );
          }

          // Soft snap: once scrolling settles near a panel, glide to it with
          // our own slow easing (native CSS snap cannot be slowed down).
          const panels = [...document.querySelectorAll('[data-hero], .section')];
          if (panels.length && matchMedia('(min-width: 861px)').matches) {
            const OFFSET = 80; // keeps panels clear of the nav, like scroll-padding-top
            // Layout position, ignoring transforms — panels mid-entrance
            // animation would otherwise skew the snap target.
            const absTop = (el) => {
              let top = 0;
              while (el) {
                top += el.offsetTop;
                el = el.offsetParent;
              }
              return top;
            };
            let settleTimer = null;
            let glideFrame = null;
            const cancelGlide = () => {
              if (glideFrame) cancelAnimationFrame(glideFrame);
              glideFrame = null;
            };
            const glide = (to) => {
              const from = window.scrollY;
              const dist = to - from;
              const duration = Math.min(
                1300,
                Math.max(700, 550 + Math.abs(dist) * 0.55),
              );
              const start = performance.now();
              const ease = (t) =>
                t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
              const step = (now) => {
                const t = Math.min(1, (now - start) / duration);
                window.scrollTo({
                  top: from + dist * ease(t),
                  behavior: 'instant',
                });
                glideFrame = t < 1 ? requestAnimationFrame(step) : null;
              };
              cancelGlide();
              glideFrame = requestAnimationFrame(step);
            };
            for (const ev of ['wheel', 'touchstart', 'keydown'])
              addEventListener(ev, cancelGlide, { passive: true });
            addEventListener(
              'scroll',
              () => {
                if (glideFrame) return; // our own glide is scrolling
                clearTimeout(settleTimer);
                settleTimer = setTimeout(() => {
                  const y = window.scrollY;
                  const max =
                    document.documentElement.scrollHeight - window.innerHeight;
                  if (y >= max - 24) return; // resting at the footer
                  let target = null;
                  let best = Infinity;
                  for (const panel of panels) {
                    const top = Math.max(0, absTop(panel) - OFFSET);
                    const d = Math.abs(top - y);
                    if (d < best) {
                      best = d;
                      target = top;
                    }
                  }
                  if (target !== null && best > 2 && best < window.innerHeight * 0.35)
                    glide(target);
                }, 170);
              },
              { passive: true },
            );
          }
        }

        const links = [
          ...document.querySelectorAll('[data-nav] a[href*="#"]'),
        ].filter((a) => a.hash && document.querySelector(a.hash));
        if (links.length) {
          const setCurrent = (hash) => {
            for (const link of links) {
              const current = !!hash && link.hash === hash;
              link.classList.toggle('current', current);
              if (current) link.setAttribute('aria-current', 'true');
              else link.removeAttribute('aria-current');
            }
            currentSection = hash ? document.querySelector(hash) : null;
            applyAccent();
          };
          const spy = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                if (entry.isIntersecting) setCurrent('#' + entry.target.id);
              }
            },
            { rootMargin: '-35% 0px -60% 0px' },
          );
          links.forEach((link) =>
            spy.observe(document.querySelector(link.hash)),
          );
          // Above the first section nothing is current (base accent); short
          // final sections never reach the spy band, so at the very bottom
          // the last section wins.
          addEventListener(
            'scroll',
            () => {
              const doc = document.documentElement;
              if (window.scrollY < 160) setCurrent(null);
              else if (
                window.innerHeight + window.scrollY >=
                doc.scrollHeight - 8
              )
                setCurrent(links[links.length - 1].hash);
            },
            { passive: true },
          );
        }
      })();
    </script>
  </body>
</html>
