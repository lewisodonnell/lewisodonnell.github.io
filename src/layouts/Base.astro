---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <script is:inline>
      // Gate for scroll-effect styles: without JS the page renders fully
      // visible, with no hidden reveal states. Also restores an explicit
      // theme choice before first paint so there is no flash.
      document.documentElement.classList.add('js');
      try {
        const theme = localStorage.getItem('theme');
        if (theme === 'dark' || theme === 'light')
          document.documentElement.setAttribute('data-theme', theme);
      } catch {}
    </script>
    <slot name="head" />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <slot />
    <Footer />
    <script is:inline>
      // The site's only JavaScript (small, no dependencies): theme toggle,
      // scroll reveals, self-drawing wave dividers, section-panel entrances,
      // 3D card tilt + spotlight, hero parallax, nav state, and scroll-spy.
      (() => {
        const motionOK = !matchMedia('(prefers-reduced-motion: reduce)')
          .matches;

        // Per-section accent: the section currently in view recolours the
        // whole page (nav, waves, spotlight, link hovers) via --accent.
        let currentSection = null;
        const isDark = () => {
          const root = document.documentElement;
          return (
            root.getAttribute('data-theme') === 'dark' ||
            (!root.getAttribute('data-theme') &&
              matchMedia('(prefers-color-scheme: dark)').matches)
          );
        };
        const applyAccent = () => {
          const root = document.documentElement;
          const colour =
            currentSection &&
            (isDark()
              ? currentSection.dataset.accentDark
              : currentSection.dataset.accent);
          if (colour) root.style.setProperty('--accent', colour);
          else root.style.removeProperty('--accent');
        };
        matchMedia('(prefers-color-scheme: dark)').addEventListener(
          'change',
          applyAccent,
        );

        const toggle = document.querySelector('[data-theme-toggle]');
        if (toggle) {
          toggle.addEventListener('click', () => {
            const next = isDark() ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            try {
              localStorage.setItem('theme', next);
            } catch {}
            applyAccent();
          });
        }

        const nav = document.querySelector('[data-nav]');
        if (nav) {
          const onScroll = () =>
            nav.classList.toggle('scrolled', window.scrollY > 8);
          onScroll();
          addEventListener('scroll', onScroll, { passive: true });
        }

        // Toggled (not one-shot) so the reveals and wave draws replay every
        // time an element scrolls back into view. On exit we record which
        // edge the element left through — it re-enters from that side
        // (data-from drives the direction-aware hidden transforms).
        const reveal = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
              } else {
                entry.target.classList.remove('in-view');
                entry.target.dataset.from =
                  entry.boundingClientRect.top < 0 ? 'above' : 'below';
              }
            }
          },
          { rootMargin: '0px 0px -8% 0px' },
        );
        document
          .querySelectorAll('.reveal, svg.divider')
          .forEach((el) => reveal.observe(el));

        // Deck mode: each panel rides a tall runway and pins full-screen, so
        // at rest exactly one panel is visible; neighbours only appear while
        // scrolling. Enabled when every panel fits the viewport — otherwise
        // (small screens, overflowing content, no JS) it stays a plain stack.
        const tracks = [...document.querySelectorAll('.panel-track')];
        const panels = tracks.map((t) => t.firstElementChild);
        const absTop = (el) => {
          let top = 0;
          while (el) {
            top += el.offsetTop;
            el = el.offsetParent;
          }
          return top;
        };
        let deckOn = false;
        let rests = [];
        let panelTops = [];
        // All geometry is cached here so the per-frame drift loop performs
        // zero layout reads (reads mid-scroll cause main-thread jank).
        const measureDeck = () => {
          deckOn = tracks.length > 0 && matchMedia('(min-width: 861px)').matches;
          document.documentElement.classList.toggle('deck', deckOn);
          if (!deckOn) {
            for (const p of panels) {
              p.style.transform = '';
              p.style.opacity = '';
            }
            return;
          }
          panelTops = panels.map((p) => absTop(p));
          // A panel is "at rest" when its top sits just below the nav.
          rests = panelTops.map((top) => Math.max(0, top - 80));
        };
        measureDeck();
        addEventListener('load', measureDeck);
        let resizeTimer = null;
        addEventListener('resize', () => {
          clearTimeout(resizeTimer);
          resizeTimer = setTimeout(measureDeck, 150);
        });

        if (motionOK) {
          // 3D tilt toward the cursor + spotlight position.
          document.querySelectorAll('.card').forEach((card) => {
            card.addEventListener('mousemove', (e) => {
              const r = card.getBoundingClientRect();
              const px = (e.clientX - r.left) / r.width;
              const py = (e.clientY - r.top) / r.height;
              card.style.transition =
                'transform 120ms ease, box-shadow 300ms ease, border-color 300ms ease';
              card.style.transform =
                'perspective(700px)' +
                ` rotateX(${((0.5 - py) * 6).toFixed(2)}deg)` +
                ` rotateY(${((px - 0.5) * 8).toFixed(2)}deg)` +
                ' translateY(-4px)';
              card.style.setProperty('--mx', (px * 100).toFixed(1) + '%');
              card.style.setProperty('--my', (py * 100).toFixed(1) + '%');
            });
            card.addEventListener('mouseleave', () => {
              card.style.transform = '';
              card.style.transition = '';
            });
          });

          // Scroll-driven drift, purely ADDITIVE on top of native motion:
          // a panel scrolling out above accelerates away, shrinks and fades
          // (the abyss); a panel arriving from below scales/fades up to
          // full. Every transform is a smooth function of scroll position
          // with zero offset at rest, so nothing ever catches or jumps.
          if (tracks.length) {
            const OFFSET = 80;
            let framePending = false;
            const drift = () => {
              framePending = false;
              if (!deckOn) return;
              const y = window.scrollY;
              const vh = window.innerHeight;
              for (let i = 0; i < panels.length; i++) {
                const el = panels[i];
                const t = panelTops[i] - y; // viewport position of panel top
                if (t < OFFSET) {
                  // Exit: scrolled past its rest — drift into the abyss.
                  const p = Math.min(1, (OFFSET - t) / (vh * 0.5));
                  const pp = p * p; // eases in from zero — seamless at rest
                  const fade = Math.min(1, Math.max(0, (p - 0.2) / 0.7));
                  el.style.transform =
                    `translateY(${(-120 * pp).toFixed(1)}px)` +
                    ` scale(${(1 - 0.1 * pp).toFixed(4)})`;
                  el.style.opacity = (1 - fade).toFixed(3);
                } else {
                  // Entry: rising from below, normalising on arrival.
                  const q = Math.min(1, (t - OFFSET) / (vh - OFFSET));
                  if (q > 0.001) {
                    el.style.transform = `scale(${(1 - 0.05 * q).toFixed(4)})`;
                    el.style.opacity = (1 - 0.55 * q).toFixed(3);
                  } else if (el.style.transform !== '') {
                    el.style.transform = '';
                    el.style.opacity = '';
                  }
                }
              }
            };
            const queueDrift = () => {
              if (!framePending) {
                framePending = true;
                requestAnimationFrame(drift);
              }
            };
            queueDrift();
            addEventListener('scroll', queueDrift, { passive: true });
            addEventListener('resize', queueDrift, { passive: true });
            addEventListener('load', queueDrift);

            // Scrolling itself is 100% browser-native and continuous — no
            // wheel interception, no CSS snap catching at panels. Alignment
            // happens only once scrolling has fully stopped: the browser's
            // scrollend event (fires after momentum completes, so it cannot
            // engage mid-gesture), with a stillness-checked idle fallback
            // for browsers without scrollend. Any input cancels instantly.
            let springActive = false;
            let springTarget = 0;
            let springPos = 0;
            let springLastT = 0;
            const springStep = (now) => {
              if (!springActive) return;
              // If anything else moved the page (programmatic jump, anchor,
              // find-in-page), yield rather than fight it.
              if (Math.abs(window.scrollY - springPos) > 60) {
                springActive = false;
                return;
              }
              const dt = Math.min(0.05, (now - springLastT) / 1000);
              springLastT = now;
              springPos +=
                (springTarget - springPos) * (1 - Math.exp(-4.2 * dt));
              if (Math.abs(springTarget - springPos) < 0.5) {
                springPos = springTarget;
                springActive = false;
              }
              window.scrollTo({ top: springPos, behavior: 'instant' });
              if (springActive) requestAnimationFrame(springStep);
            };
            const springTo = (target) => {
              springTarget = target;
              if (!springActive) {
                springActive = true;
                springPos = window.scrollY;
                springLastT = performance.now();
                requestAnimationFrame(springStep);
              }
            };
            const cancelSpring = () => {
              springActive = false;
            };
            for (const ev of ['wheel', 'touchstart', 'keydown', 'mousedown'])
              addEventListener(ev, cancelSpring, { passive: true });

            let lastY = window.scrollY;
            let scrollDir = 1;
            addEventListener(
              'scroll',
              () => {
                const yNow = window.scrollY;
                if (yNow !== lastY) scrollDir = yNow > lastY ? 1 : -1;
                lastY = yNow;
              },
              { passive: true },
            );

            const settle = () => {
              if (!deckOn || springActive) return;
              const y = window.scrollY;
              // Beyond the last panel's rest is footer territory — free.
              if (y > rests[rests.length - 1] + 4) return;
              let prev = rests[0];
              let next = rests[rests.length - 1];
              for (const rest of rests) {
                if (rest <= y) prev = rest;
                else {
                  next = rest;
                  break;
                }
              }
              let target = prev;
              if (next !== prev) {
                const progress = (y - prev) / (next - prev);
                if (progress < 0.08) target = prev;
                else if (progress > 0.92) target = next;
                else target = scrollDir > 0 ? next : prev;
              }
              if (Math.abs(target - y) > 2) springTo(target);
            };
            // Settle only after the page has been truly still: scrollend
            // alone fires between discrete wheel notches when rolling, and a
            // naive idle timer can fire inside sparse momentum tails — the
            // stillness re-check defeats both.
            const settleWhenStill = () => {
              const y0 = window.scrollY;
              setTimeout(() => {
                if (window.scrollY === y0 && !springActive) settle();
              }, 160);
            };
            if ('onscrollend' in window) {
              addEventListener('scrollend', settleWhenStill);
            } else {
              let idleTimer = null;
              addEventListener(
                'scroll',
                () => {
                  clearTimeout(idleTimer);
                  idleTimer = setTimeout(settleWhenStill, 320);
                },
                { passive: true },
              );
            }
          }
        }

        const links = [
          ...document.querySelectorAll('[data-nav] a[href*="#"]'),
        ].filter((a) => a.hash && document.querySelector(a.hash));
        if (links.length) {
          const setCurrent = (hash) => {
            for (const link of links) {
              const current = !!hash && link.hash === hash;
              link.classList.toggle('current', current);
              if (current) link.setAttribute('aria-current', 'true');
              else link.removeAttribute('aria-current');
            }
            currentSection = hash ? document.querySelector(hash) : null;
            applyAccent();
          };
          const spy = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                if (entry.isIntersecting) setCurrent('#' + entry.target.id);
              }
            },
            { rootMargin: '-35% 0px -60% 0px' },
          );
          links.forEach((link) =>
            spy.observe(document.querySelector(link.hash)),
          );
          // Above the first section nothing is current (base accent); short
          // final sections never reach the spy band, so at the very bottom
          // the last section wins.
          addEventListener(
            'scroll',
            () => {
              const doc = document.documentElement;
              if (window.scrollY < 160) setCurrent(null);
              else if (
                window.innerHeight + window.scrollY >=
                doc.scrollHeight - 8
              )
                setCurrent(links[links.length - 1].hash);
            },
            { passive: true },
          );
        }
      })();
    </script>
  </body>
</html>
