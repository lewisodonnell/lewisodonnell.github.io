---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description: string;
}
const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
    <script is:inline>
      // Gate for scroll-effect styles: without JS the page renders fully
      // visible, with no hidden reveal states. Also restores an explicit
      // theme choice before first paint so there is no flash.
      document.documentElement.classList.add('js');
      try {
        const theme = localStorage.getItem('theme');
        if (theme === 'dark' || theme === 'light')
          document.documentElement.setAttribute('data-theme', theme);
      } catch {}
    </script>
    <slot name="head" />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <slot />
    <Footer />
    <script is:inline>
      // The site's only JavaScript (small, no dependencies): theme toggle,
      // scroll reveals, self-drawing wave dividers, section-panel entrances,
      // 3D card tilt + spotlight, hero parallax, nav state, and scroll-spy.
      (() => {
        const motionOK = !matchMedia('(prefers-reduced-motion: reduce)')
          .matches;

        // Per-section accent: the section currently in view recolours the
        // whole page (nav, waves, spotlight, link hovers) via --accent.
        let currentSection = null;
        const isDark = () => {
          const root = document.documentElement;
          return (
            root.getAttribute('data-theme') === 'dark' ||
            (!root.getAttribute('data-theme') &&
              matchMedia('(prefers-color-scheme: dark)').matches)
          );
        };
        const applyAccent = () => {
          const root = document.documentElement;
          const colour =
            currentSection &&
            (isDark()
              ? currentSection.dataset.accentDark
              : currentSection.dataset.accent);
          if (colour) root.style.setProperty('--accent', colour);
          else root.style.removeProperty('--accent');
        };
        matchMedia('(prefers-color-scheme: dark)').addEventListener(
          'change',
          applyAccent,
        );

        const toggle = document.querySelector('[data-theme-toggle]');
        if (toggle) {
          toggle.addEventListener('click', () => {
            const next = isDark() ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            try {
              localStorage.setItem('theme', next);
            } catch {}
            applyAccent();
          });
        }

        const nav = document.querySelector('[data-nav]');
        if (nav) {
          const onScroll = () =>
            nav.classList.toggle('scrolled', window.scrollY > 8);
          onScroll();
          addEventListener('scroll', onScroll, { passive: true });
        }

        // Toggled (not one-shot) so the reveals and wave draws replay every
        // time an element scrolls back into view. On exit we record which
        // edge the element left through — it re-enters from that side
        // (data-from drives the direction-aware hidden transforms).
        const reveal = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add('in-view');
              } else {
                entry.target.classList.remove('in-view');
                entry.target.dataset.from =
                  entry.boundingClientRect.top < 0 ? 'above' : 'below';
              }
            }
          },
          { rootMargin: '0px 0px -8% 0px' },
        );
        document
          .querySelectorAll('.reveal, svg.divider')
          .forEach((el) => reveal.observe(el));

        // Deck mode: each panel rides a tall runway and pins full-screen, so
        // at rest exactly one panel is visible; neighbours only appear while
        // scrolling. Enabled when every panel fits the viewport — otherwise
        // (small screens, overflowing content, no JS) it stays a plain stack.
        const tracks = [...document.querySelectorAll('.panel-track')];
        const absTop = (el) => {
          let top = 0;
          while (el) {
            top += el.offsetTop;
            el = el.offsetParent;
          }
          return top;
        };
        let deckOn = false;
        let rests = [];
        let trackTops = [];
        const measureDeck = () => {
          deckOn =
            tracks.length > 0 &&
            matchMedia('(min-width: 861px)').matches &&
            tracks.every(
              (t) => t.firstElementChild.offsetHeight <= innerHeight - 70,
            );
          document.documentElement.classList.toggle('deck', deckOn);
          if (!deckOn) {
            for (const t of tracks) {
              t.firstElementChild.style.transform = '';
              t.firstElementChild.style.opacity = '';
            }
            return;
          }
          trackTops = tracks.map((t) => absTop(t));
          rests = trackTops.map((top, i) => (i === 0 ? 0 : top));
        };
        measureDeck();
        addEventListener('load', measureDeck);
        let resizeTimer = null;
        addEventListener('resize', () => {
          clearTimeout(resizeTimer);
          resizeTimer = setTimeout(measureDeck, 150);
        });

        if (motionOK) {
          // 3D tilt toward the cursor + spotlight position.
          document.querySelectorAll('.card').forEach((card) => {
            card.addEventListener('mousemove', (e) => {
              const r = card.getBoundingClientRect();
              const px = (e.clientX - r.left) / r.width;
              const py = (e.clientY - r.top) / r.height;
              card.style.transition =
                'transform 120ms ease, box-shadow 300ms ease, border-color 300ms ease';
              card.style.transform =
                'perspective(700px)' +
                ` rotateX(${((0.5 - py) * 6).toFixed(2)}deg)` +
                ` rotateY(${((px - 0.5) * 8).toFixed(2)}deg)` +
                ' translateY(-4px)';
              card.style.setProperty('--mx', (px * 100).toFixed(1) + '%');
              card.style.setProperty('--my', (py * 100).toFixed(1) + '%');
            });
            card.addEventListener('mouseleave', () => {
              card.style.transform = '';
              card.style.transition = '';
            });
          });

          // Scroll-driven drift: the resting panel fades, shrinks and rises
          // into the abyss as the next one slides up — fully gone before you
          // arrive. Runs every scroll frame in both directions.
          if (tracks.length) {
            const OFFSET = 80;
            let framePending = false;
            const drift = () => {
              framePending = false;
              if (!deckOn) return;
              const y = window.scrollY;
              const vh = window.innerHeight;
              tracks.forEach((t, i) => {
                const el = t.firstElementChild;
                const isLast = i === tracks.length - 1;
                // Exit: progress from this panel's rest towards the next.
                const span = isLast
                  ? Infinity
                  : (rests[i + 1] - rests[i]) * 0.8;
                const ex = Math.min(1, Math.max(0, (y - rests[i]) / span));
                // Entry: progress sliding up from the viewport bottom.
                const en = Math.min(
                  1,
                  Math.max(0, (vh - (trackTops[i] - y)) / (vh - OFFSET)),
                );
                if (ex > 0) {
                  const e = ex * ex;
                  el.style.transform =
                    `translateY(${(-70 * e).toFixed(1)}px)` +
                    ` scale(${(1 - 0.14 * e).toFixed(4)})`;
                  el.style.opacity = (1 - ex).toFixed(3);
                } else if (en < 1) {
                  el.style.transform = `scale(${(0.96 + 0.04 * en).toFixed(4)})`;
                  el.style.opacity = (0.35 + 0.65 * en).toFixed(3);
                } else {
                  el.style.transform = '';
                  el.style.opacity = '';
                }
              });
            };
            const queueDrift = () => {
              if (!framePending) {
                framePending = true;
                requestAnimationFrame(drift);
              }
            };
            queueDrift();
            addEventListener('scroll', queueDrift, { passive: true });
            addEventListener('resize', queueDrift, { passive: true });
            addEventListener('load', queueDrift);

            // One continuous spring drives all assisted motion: the page
            // exponentially eases toward a target, and new gestures simply
            // move the target — chained flicks flow into one another with no
            // stop between panels.
            let springActive = false;
            let springTarget = 0;
            let springPos = 0;
            let springLastT = 0;
            const springStep = (now) => {
              if (!springActive) return;
              const dt = Math.min(0.05, (now - springLastT) / 1000);
              springLastT = now;
              const k = 1 - Math.exp(-4.2 * dt);
              springPos += (springTarget - springPos) * k;
              if (Math.abs(springTarget - springPos) < 0.5) {
                springPos = springTarget;
                springActive = false;
              }
              window.scrollTo({ top: springPos, behavior: 'instant' });
              if (springActive) requestAnimationFrame(springStep);
            };
            const springTo = (target) => {
              springTarget = target;
              if (!springActive) {
                springActive = true;
                springPos = window.scrollY;
                springLastT = performance.now();
                requestAnimationFrame(springStep);
              }
            };
            const cancelSpring = () => {
              springActive = false;
            };
            // Scrolling itself is fully native — no wheel interception, no
            // preventDefault. Any user input immediately takes authority
            // back from the settle spring.
            for (const ev of ['wheel', 'touchstart', 'keydown', 'mousedown'])
              addEventListener(ev, cancelSpring, { passive: true });

            // Settle: once native scrolling pauses between two rests, ease
            // to one of them — continuing in the direction of travel past
            // 8% of the gap, so a flick plus its momentum lands forward.
            let settleTimer = null;
            let lastY = window.scrollY;
            let scrollDir = 1;
            addEventListener(
              'scroll',
              () => {
                const yNow = window.scrollY;
                if (yNow !== lastY) scrollDir = yNow > lastY ? 1 : -1;
                lastY = yNow;
                if (springActive || !deckOn) return;
                clearTimeout(settleTimer);
                settleTimer = setTimeout(() => {
                  const y = window.scrollY;
                  if (springActive || !deckOn) return;
                  // Beyond the last panel's rest is footer territory — free.
                  if (y > rests[rests.length - 1] + 4) return;
                  let prev = rests[0];
                  let next = rests[rests.length - 1];
                  for (const rest of rests) {
                    if (rest <= y) prev = rest;
                    else {
                      next = rest;
                      break;
                    }
                  }
                  let target = prev;
                  if (next !== prev) {
                    const progress = (y - prev) / (next - prev);
                    if (progress < 0.08) target = prev;
                    else if (progress > 0.92) target = next;
                    else target = scrollDir > 0 ? next : prev;
                  }
                  if (Math.abs(target - y) > 2) springTo(target);
                }, 170);
              },
              { passive: true },
            );
          }
        }

        const links = [
          ...document.querySelectorAll('[data-nav] a[href*="#"]'),
        ].filter((a) => a.hash && document.querySelector(a.hash));
        if (links.length) {
          const setCurrent = (hash) => {
            for (const link of links) {
              const current = !!hash && link.hash === hash;
              link.classList.toggle('current', current);
              if (current) link.setAttribute('aria-current', 'true');
              else link.removeAttribute('aria-current');
            }
            currentSection = hash ? document.querySelector(hash) : null;
            applyAccent();
          };
          const spy = new IntersectionObserver(
            (entries) => {
              for (const entry of entries) {
                if (entry.isIntersecting) setCurrent('#' + entry.target.id);
              }
            },
            { rootMargin: '-35% 0px -60% 0px' },
          );
          links.forEach((link) =>
            spy.observe(document.querySelector(link.hash)),
          );
          // Above the first section nothing is current (base accent); short
          // final sections never reach the spy band, so at the very bottom
          // the last section wins.
          addEventListener(
            'scroll',
            () => {
              const doc = document.documentElement;
              if (window.scrollY < 160) setCurrent(null);
              else if (
                window.innerHeight + window.scrollY >=
                doc.scrollHeight - 8
              )
                setCurrent(links[links.length - 1].hash);
            },
            { passive: true },
          );
        }
      })();
    </script>
  </body>
</html>
