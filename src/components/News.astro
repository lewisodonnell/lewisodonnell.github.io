---
import news from '../data/news.yaml';

type Item = { date: string; text: string };

const items = ([...news] as Item[]).sort((a, b) =>
  b.date.localeCompare(a.date),
);

const fmt = (d: string) =>
  new Date(`${d}-01T00:00:00Z`).toLocaleDateString('en-GB', {
    month: 'short',
    year: 'numeric',
    timeZone: 'UTC',
  });
---

<ul class="news" role="list">
  {
    items.map((item) => (
      <li>
        <time class="date" datetime={item.date}>
          {fmt(item.date)}
        </time>
        <span class="text" set:html={item.text} />
      </li>
    ))
  }
</ul>

<style>
  .news {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  li {
    display: grid;
    grid-template-columns: 6.5rem 1fr;
    gap: var(--space-3);
    padding: var(--space-2) 0;
  }

  .date {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--ink-secondary);
    padding-top: 0.22em;
  }
</style>
