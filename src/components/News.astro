---
import news from '../data/news.yaml';

type Item = { date: string; text: string };

const items = ([...news] as Item[]).sort((a, b) =>
  b.date.localeCompare(a.date),
);

const fmt = (d: string) =>
  new Date(`${d}-01T00:00:00Z`).toLocaleDateString('en-GB', {
    month: 'short',
    year: 'numeric',
    timeZone: 'UTC',
  });
---

<ul class="news" role="list">
  {
    items.map((item, i) => (
      <li class="card reveal" style={`--i: ${i}`}>
        <time class="date" datetime={item.date}>
          {fmt(item.date)}
        </time>
        <span class="text" set:html={item.text} />
      </li>
    ))
  }
</ul>

<style>
  .news {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  li {
    padding: 1.15rem 1.3rem;
  }

  .date {
    display: block;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--ink-secondary);
    margin-bottom: var(--space-2);
  }

  .text {
    display: block;
  }

  @media (max-width: 900px) {
    .news {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .news {
      grid-template-columns: 1fr;
    }
  }
</style>
