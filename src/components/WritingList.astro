---
import type { CollectionEntry } from 'astro:content';

interface Props {
  posts: CollectionEntry<'blog'>[];
}
const { posts } = Astro.props;

const fmt = (d: Date) =>
  d.toLocaleDateString('en-GB', {
    day: 'numeric',
    month: 'short',
    year: 'numeric',
    timeZone: 'UTC',
  });
---

{
  posts.length === 0 ? (
    <p class="empty">Nothing here yet.</p>
  ) : (
    <ul class="posts" role="list">
      {posts.map((post) => (
        <li>
          <time class="date" datetime={post.data.date.toISOString().slice(0, 10)}>
            {fmt(post.data.date)}
          </time>
          <div>
            <a class="title" href={`/blog/${post.id}/`}>
              {post.data.title}
            </a>
            <p class="summary">{post.data.summary}</p>
          </div>
        </li>
      ))}
    </ul>
  )
}

<style>
  .posts {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  li {
    display: grid;
    grid-template-columns: 6.5rem 1fr;
    gap: var(--space-3);
    padding: var(--space-2) 0;
  }

  .date {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--ink-secondary);
    padding-top: 0.32em;
  }

  .title {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-size: var(--step-1);
    line-height: 1.3;
  }

  .summary {
    margin: var(--space-1) 0 0;
    color: var(--ink-secondary);
    font-size: 0.9375rem;
  }

  .empty {
    color: var(--ink-secondary);
    margin: 0;
  }
</style>
