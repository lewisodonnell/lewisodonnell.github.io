---
import projects from '../data/projects.yaml';

type Project = {
  name: string;
  image?: string;
  imageAlt?: string;
  description: string;
  links?: Record<string, string>;
};

const items = projects as Project[];

const real = (url?: string) =>
  !!url && (url.startsWith('http') || url.startsWith('/'));
---

<ul class="projects" role="list">
  {
    items.map((p, i) => {
      const links = Object.entries(p.links ?? {}).filter(([, url]) =>
        real(url),
      );
      return (
        <li class="project card reveal" style={`--i: ${i}`}>
          {real(p.image) && (
            <img
              class="image"
              src={p.image}
              alt={p.imageAlt ?? ''}
              width="360"
              height="200"
              loading="lazy"
              decoding="async"
            />
          )}
          <div class="body">
            <h3>{p.name}</h3>
            <p class="desc">{p.description}</p>
            {links.length > 0 && (
              <p class="links">
                {links.map(([label, url]) => (
                  <a href={url}>{label}</a>
                ))}
              </p>
            )}
          </div>
        </li>
      );
    })
  }
</ul>

<style>
  .projects {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .project {
    overflow: hidden; /* clips the image to the card radius */
    display: flex;
    flex-direction: column;
  }

  .image {
    width: 100%;
    height: 11rem;
    object-fit: cover;
    border-bottom: 1px solid var(--hairline);
  }

  .body {
    padding: 1.3rem 1.4rem;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  h3 {
    font-size: var(--step-1);
    line-height: 1.3;
    margin: 0 0 var(--space-2);
  }

  .desc {
    margin: 0;
  }

  .links {
    margin: var(--space-3) 0 0;
    padding-top: var(--space-3);
    margin-top: auto;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
  }

  @media (max-width: 980px) {
    .projects {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 640px) {
    .projects {
      grid-template-columns: 1fr;
    }
  }
</style>
