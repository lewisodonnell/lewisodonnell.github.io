---
import SignalDivider from './SignalDivider.astro';

interface Props {
  id: string;
  title: string;
  seed?: number;
}
const { id, title, seed } = Astro.props;
---

<section id={id} aria-labelledby={`${id}-heading`} class="section">
  <SignalDivider seed={seed} />
  <h2 id={`${id}-heading`} class="reveal">{title}</h2>
  <slot />
</section>

<style>
  .section {
    margin-top: clamp(var(--space-6), 8vh, var(--space-7));
  }

  h2 {
    font-size: 1.75rem;
    margin: var(--space-4) 0;
  }
</style>
