---
import SignalDivider from './SignalDivider.astro';

interface Props {
  id: string;
  title: string;
  /** Section accent (light theme) — becomes the page-wide --accent while
      this section is in view, and tints the panel background. */
  accent: string;
  /** Brighter accent variant used while the dark theme is active. */
  accentDark: string;
  /** Background texture for this panel. */
  texture?: 'grain' | 'grid' | 'dots' | 'hatch' | 'scan';
}
const { id, title, accent, accentDark, texture = 'grain' } = Astro.props;
---

<div class="panel-track">
  <section
    id={id}
    aria-labelledby={`${id}-heading`}
    class="section"
    data-accent={accent}
    data-accent-dark={accentDark}
    data-texture={texture}
    style={`--tint: ${accent}`}
  >
    <SignalDivider />
    <h2 id={`${id}-heading`} class="reveal">{title}</h2>
    <slot />
  </section>
</div>

<style>
  /* Each section is a full-height floating panel: its own accent tint,
     texture, border and long shadow — planes stacked over the page mesh. */
  .section {
    position: relative;
    overflow: hidden;
    min-height: min(86vh, 56rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    margin: 2.75rem 0;
    padding: 3rem 3.25rem;
    background: linear-gradient(
      175deg,
      color-mix(in srgb, var(--tint, transparent) 6%, var(--card-bg)),
      var(--card-bg) 55%
    );
    border: 1px solid var(--hairline);
    border-radius: 24px;
    box-shadow: var(--panel-shadow);
  }

  .section::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image: var(--grain);
    opacity: 0.6;
    border-radius: inherit;
  }

  .section[data-texture='grid']::before {
    opacity: 1;
    background-image: linear-gradient(
        color-mix(in srgb, var(--ink) 5%, transparent) 1px,
        transparent 1px
      ),
      linear-gradient(
        90deg,
        color-mix(in srgb, var(--ink) 5%, transparent) 1px,
        transparent 1px
      );
    background-size: 28px 28px;
  }

  .section[data-texture='dots']::before {
    opacity: 1;
    background-image: radial-gradient(
      color-mix(in srgb, var(--ink) 9%, transparent) 1px,
      transparent 1.5px
    );
    background-size: 18px 18px;
  }

  .section[data-texture='hatch']::before {
    opacity: 1;
    background-image: repeating-linear-gradient(
      -45deg,
      color-mix(in srgb, var(--ink) 4%, transparent) 0 1px,
      transparent 1px 13px
    );
  }

  .section[data-texture='scan']::before {
    opacity: 1;
    background-image: repeating-linear-gradient(
      180deg,
      color-mix(in srgb, var(--ink) 5%, transparent) 0 1px,
      transparent 1px 9px
    );
  }

  h2 {
    font-size: clamp(1.75rem, 3vw, 2.2rem);
    margin: var(--space-4) 0;
  }

  @media (max-width: 860px) {
    .section {
      min-height: 0;
      justify-content: flex-start;
      margin: 1.5rem 0;
      padding: 1.75rem 1.25rem;
      border-radius: 18px;
    }

  }
</style>
