---
import publications from '../data/publications.yaml';

type Pub = {
  title: string;
  authors: string[];
  venue?: string;
  year?: number;
  thumbnail?: string;
  links?: Record<string, string>;
};

const pubs = publications as Pub[];

// Placeholder values (e.g. "[FILL: …]") are kept out of the rendered page;
// only real URLs become links or thumbnails.
const real = (url?: string) =>
  !!url && (url.startsWith('http') || url.startsWith('/'));
const isMe = (author: string) =>
  author.replace(/[’']/g, '').includes('ODonnell');
---

<ul class="pubs" role="list">
  {
    pubs.map((pub, i) => {
      const links = Object.entries(pub.links ?? {}).filter(([, url]) =>
        real(url),
      );
      return (
        <li
          class:list={['pub', 'card', 'reveal', { 'has-thumb': real(pub.thumbnail) }]}
          style={`--i: ${i}`}
        >
          <div>
            <p class="title">{pub.title}</p>
            <p class="authors">
              {pub.authors.map((a, j) => (
                /* prettier-ignore */
                <span>{isMe(a) ? <strong>{a}</strong> : a}{j < pub.authors.length - 1 ? ', ' : ''}</span>
              ))}
            </p>
            <p class="meta">
              {[pub.venue, pub.year].filter(Boolean).join(' · ')}
            </p>
            {links.length > 0 && (
              <p class="links">
                {links.map(([label, url]) => (
                  <a href={url}>{label}</a>
                ))}
              </p>
            )}
          </div>
          {real(pub.thumbnail) && (
            <img
              class="thumb"
              src={pub.thumbnail}
              alt=""
              width="96"
              height="96"
              loading="lazy"
              decoding="async"
            />
          )}
        </li>
      );
    })
  }
</ul>

<style>
  .pubs {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .pub {
    padding: 1.4rem 1.5rem;
  }

  .pub.has-thumb {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 1.1rem;
    align-items: start;
  }

  .thumb {
    width: 6rem;
    height: 6rem;
    object-fit: cover;
    border: 1px solid var(--hairline);
    border-radius: 10px;
  }

  .title {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-size: var(--step-1);
    line-height: 1.3;
    margin: 0 0 var(--space-2);
  }

  .authors {
    margin: 0 0 var(--space-1);
  }

  .authors strong {
    font-weight: 600;
  }

  .meta {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--ink-secondary);
    margin: 0;
  }

  .links {
    margin: var(--space-3) 0 0;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
  }

  @media (max-width: 760px) {
    .pubs {
      grid-template-columns: 1fr;
    }
  }
</style>
