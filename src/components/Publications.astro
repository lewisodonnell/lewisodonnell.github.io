---
import publications from '../data/publications.yaml';

type Pub = {
  title: string;
  authors: string[];
  venue?: string;
  year?: number;
  thumbnail?: string;
  links?: Record<string, string>;
};

const pubs = publications as Pub[];

// Placeholder values (e.g. "[FILL: …]") are kept out of the rendered page;
// only real URLs become links or thumbnails.
const real = (url?: string) =>
  !!url && (url.startsWith('http') || url.startsWith('/'));
const isMe = (author: string) =>
  author.replace(/[’']/g, '').includes('ODonnell');
---

<ul class="pubs" role="list">
  {
    pubs.map((pub) => {
      const links = Object.entries(pub.links ?? {}).filter(([, url]) =>
        real(url),
      );
      return (
        <li class:list={['pub', { 'has-thumb': real(pub.thumbnail) }]}>
          {real(pub.thumbnail) && (
            <img
              class="thumb"
              src={pub.thumbnail}
              alt=""
              width="120"
              height="90"
              loading="lazy"
              decoding="async"
            />
          )}
          <div>
            <p class="title">{pub.title}</p>
            <p class="authors">
              {pub.authors.map((a, i) => (
                /* prettier-ignore */
                <span>{isMe(a) ? <strong>{a}</strong> : a}{i < pub.authors.length - 1 ? ', ' : ''}</span>
              ))}
            </p>
            <p class="meta">
              {[pub.venue, pub.year].filter(Boolean).join(' · ')}
            </p>
            {links.length > 0 && (
              <p class="links">
                {links.map(([label, url]) => (
                  <a href={url}>{label}</a>
                ))}
              </p>
            )}
          </div>
        </li>
      );
    })
  }
</ul>

<style>
  .pubs {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .pub {
    margin-bottom: var(--space-5);
  }

  .pub:last-child {
    margin-bottom: 0;
  }

  .pub.has-thumb {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-4);
    align-items: start;
  }

  .thumb {
    width: 7.5rem;
    height: 5.625rem;
    object-fit: cover;
    border: 1px solid var(--hairline);
  }

  .title {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-size: var(--step-1);
    line-height: 1.3;
    margin: 0 0 var(--space-1);
  }

  .authors {
    margin: 0 0 var(--space-1);
  }

  .authors strong {
    font-weight: 600;
  }

  .meta {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    color: var(--ink-secondary);
    margin: 0;
  }

  .links {
    margin: var(--space-1) 0 0;
    font-family: var(--font-mono);
    font-size: var(--step--1);
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
  }

  @media (max-width: 480px) {
    .pub.has-thumb {
      grid-template-columns: 1fr;
    }
  }
</style>
