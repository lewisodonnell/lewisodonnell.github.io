---
// Section divider: a centered sinusoidal wave packet — a clean sine
// concentrated at the middle of the line, fading flat toward the edges.
// It draws itself in on scroll (pathLength + stroke-dashoffset, see
// global.css). Rendered inline at build time.
const W = 640;
const H = 24;
const MID = 12;

const parts: string[] = [];
for (let x = 0; x <= W; x += 4) {
  const s = (x - W / 2) / (W / 7);
  const amplitude = 7 * Math.exp(-s * s);
  const y = MID + amplitude * Math.sin((2 * Math.PI * x) / 90);
  parts.push(`${x === 0 ? 'M' : 'L'}${x} ${y.toFixed(2)}`);
}
const d = parts.join(' ');
---

<svg
  class="divider"
  viewBox={`0 0 ${W} ${H}`}
  preserveAspectRatio="none"
  aria-hidden="true"
>
  <path
    d={d}
    fill="none"
    stroke="var(--accent)"
    stroke-width="1"
    opacity="0.9"
    vector-effect="non-scaling-stroke"
    pathLength="1"></path>
</svg>

<style>
  .divider {
    display: block;
    width: 100%;
    height: 24px;
  }
</style>
