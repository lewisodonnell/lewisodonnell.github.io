---
// The one allowed flourish: section dividers drawn as a thin signal trace —
// a quiet baseline with one brief burst of activity, like a plasma
// diagnostic time series. The burst is the only place the accent colour
// appears at rest. Rendered inline at build time; no client JavaScript.
interface Props {
  seed?: number;
}
const { seed = 1 } = Astro.props;

// Deterministic PRNG (mulberry32) so each divider differs by seed but
// builds are reproducible.
function mulberry32(a: number) {
  return () => {
    a |= 0;
    a = (a + 0x6d2b79f5) | 0;
    let t = Math.imul(a ^ (a >>> 15), 1 | a);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
const rand = mulberry32(seed * 9973 + 17);

const W = 640;
const H = 24;
const MID = 13;

const burstStart = Math.round((90 + rand() * (W - 320)) / 4) * 4;
const burstLen = 60 + Math.round(rand() * 6) * 4;

// Quiescent baseline sampled coarsely with sub-pixel noise; the burst
// sampled finely so the ringing resolves.
const pts: [number, number][] = [];
let x = 0;
while (x <= W) {
  const inBurst = x >= burstStart && x <= burstStart + burstLen;
  let y: number;
  if (inBurst) {
    // Sharp rise, ringing decay — an ELM-ish spike.
    const t = (x - burstStart) / burstLen;
    const env = Math.min(1, t / 0.15) * Math.exp(-2.4 * t);
    y = MID - env * 7.5 * Math.sin(t * Math.PI * 5) - env * 1.5;
  } else {
    y = MID + (rand() - 0.5) * 0.7;
  }
  pts.push([x, Math.min(H - 2, Math.max(2, +y.toFixed(2)))]);
  x += inBurst ? 4 : 8;
}

const toPath = (p: [number, number][]) =>
  p.map(([px, py], i) => `${i === 0 ? 'M' : 'L'}${px} ${py}`).join(' ');
const burstPts = pts.filter(
  ([px]) => px >= burstStart - 8 && px <= burstStart + burstLen + 8,
);
---

<svg
  class="divider"
  viewBox={`0 0 ${W} ${H}`}
  preserveAspectRatio="none"
  aria-hidden="true"
>
  <path
    d={toPath(pts)}
    fill="none"
    stroke="var(--hairline)"
    stroke-width="1"
    vector-effect="non-scaling-stroke"></path>
  <path
    d={toPath(burstPts)}
    fill="none"
    stroke="var(--accent)"
    stroke-width="1"
    vector-effect="non-scaling-stroke"
    opacity="0.85"></path>
</svg>

<style>
  .divider {
    display: block;
    width: 100%;
    height: 24px;
  }
</style>
