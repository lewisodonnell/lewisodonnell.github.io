---
// Floating pill navigation. Transparent over the page top; gains its border,
// blur and shadow once the page scrolls (class toggled by the inline script
// in Base.astro, which also drives the scroll-spy `current` state).
import { SITE } from '../lib/site';

interface Props {
  home?: boolean;
}
const { home = false } = Astro.props;
const prefix = home ? '' : '/';

const items = [
  ['About', `${prefix}#about`],
  ['News', `${prefix}#news`],
  ['Publications', `${prefix}#publications`],
  ['Work', `${prefix}#work`],
  ['Blog', `${prefix}#blog`],
];
---

<header class="site-header">
  <div class="bar" data-nav>
    <a class="brand" href="/">{SITE.name}</a>
    <nav aria-label="Sections">
      <ul role="list">
        {
          items.map(([label, href]) => (
            <li>
              <a href={href}>{label}</a>
            </li>
          ))
        }
      </ul>
    </nav>
    <button class="theme-toggle" data-theme-toggle aria-label="Toggle dark mode">
      <svg
        class="moon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
      <svg
        class="sun"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="4"></circle>
        <path
          d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4m11.4-11.4 1.4-1.4"
        ></path>
      </svg>
    </button>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0.75rem;
    z-index: 50;
    padding-inline: clamp(0.75rem, 3vw, 2rem);
  }

  .bar {
    max-width: var(--wrap-wide);
    margin-inline: auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    padding: 0.6rem 1.4rem;
    border-radius: 999px;
    border: 1px solid transparent;
  }

  .bar.scrolled {
    background: var(--nav-bg);
    border-color: var(--hairline);
    box-shadow: var(--nav-shadow);
    -webkit-backdrop-filter: blur(10px);
    backdrop-filter: blur(10px);
  }

  @media (prefers-reduced-motion: no-preference) {
    .bar {
      transition:
        background 250ms ease,
        border-color 250ms ease,
        box-shadow 250ms ease;
    }
  }

  .brand {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-size: 1.125rem;
    text-decoration: none;
    white-space: nowrap;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 1.5rem;
    font-family: var(--font-mono);
    font-size: var(--step--1);
  }

  nav a {
    text-decoration: none;
    white-space: nowrap;
  }

  nav a:hover,
  nav a.current {
    color: var(--accent);
  }

  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    flex-shrink: 0;
    padding: 0;
    border: 0;
    border-radius: 999px;
    background: transparent;
    color: var(--ink);
    cursor: pointer;
  }

  .theme-toggle:hover {
    color: var(--accent);
  }

  .theme-toggle svg {
    width: 16px;
    height: 16px;
  }

  /* Moon shown in light mode, sun in dark mode — including system-dark. */
  .sun {
    display: none;
  }

  :global(html[data-theme='dark']) .sun {
    display: block;
  }

  :global(html[data-theme='dark']) .moon {
    display: none;
  }

  @media (prefers-color-scheme: dark) {
    :global(html:not([data-theme='light'])) .sun {
      display: block;
    }

    :global(html:not([data-theme='light'])) .moon {
      display: none;
    }
  }

  @media (max-width: 620px) {
    .brand {
      display: none;
    }

    .bar {
      padding: 0.55rem 1rem;
    }

    nav {
      flex: 1;
      min-width: 0;
    }

    ul {
      justify-content: space-between;
      gap: 0.6rem;
      overflow-x: auto;
    }
  }
</style>
